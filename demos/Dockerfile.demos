FROM python:3.10.9-slim

WORKDIR /usr/src/app

# Install dependencies including flask-cors
RUN pip install --no-cache-dir flask flask-cors

# Copy the demo server script
COPY demos/web_server.py .

# Create demo_data directory (will be mounted at runtime)
RUN mkdir -p /demos

# Expose port
EXPOSE 60000

CMD ["python", "web_server.py"]